@@ -903,13 +903,17 @@ DDSInput::seek_subimage(int subimage, int miplevel)
         m_spec.attribute("textureformat", "Plain Texture");
     }
 
+    // Check validity of resolutions.
+    if (!check_open(m_spec, { 0, 32768, 0, 32768, 0, 16384, 0, 4 }))
